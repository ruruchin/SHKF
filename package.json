{
  "name": "shkf",
  "version": "1.2.17",
  "description": "SHKF — hotkeys, Make and templates for Figma",
  "type": "module",
  "main": "app/main.js",
  "author": "SHKF",
  "repository": {
    "type": "git",
    "url": "https://github.com/ruruchin/figma-hotkeys.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "node scripts/electron-build.js nsis",
    "build:portable": "node scripts/electron-build.js portable",
    "build:all": "node scripts/electron-build.js all",
    "server": "node server/index.js",
    "site:dev": "npm --prefix site run dev",
    "site:build": "npm --prefix site run build",
    "site:preview": "npm --prefix site run preview",
    "seed:supabase": "node supabase/seed-users.mjs",
    "seed:employees": "node supabase/seed-employees.mjs",
    "pik-folder:build-mobbin": "node scripts/build-pik-folder-mobbin-catalog.mjs",
    "ml:export-dataset": "node scripts/export-agent-training-dataset.mjs",
    "ml:export-chat": "node scripts/export-konstancia-chat-dataset.mjs",
    "ml:train": "npm run ml:export-chat && npm run ml:export-dataset && python ml/train_all.py",
    "ml:train:chat": "npm run ml:export-chat && python ml/train_chat_model.py",
    "ml:train:intent": "npm run ml:export-dataset && python ml/train_intent_classifier.py",
    "ml:train:retrieval": "python ml/train_retrieval_embeddings.py",
    "ml:serve": "cd ml && uvicorn serve_api:app --host 0.0.0.0 --port 8080",
    "ml:upload-hf": "node scripts/upload-konstancia-to-hf.mjs"
  },
  "build": {
    "appId": "app.shkf",
    "productName": "SHKF",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ruruchin",
        "repo": "SHKF",
        "releaseType": "release"
      }
    ],
    "files": [
      "app/**/*",
      "server/**/*",
      "shared/**/*",
      "config/**/*",
      "supabase/migrations/**/*",
      "scripts/**/*",
      "ml/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/node-global-key-listener/bin/**/*",
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*",
      "scripts/**/*"
    ],
    "extraResources": [
      {
        "from": "figma-plugin",
        "to": "figma-plugin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "config",
        "to": "config-default",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "scripts",
        "to": "scripts",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "artifactName": "SHKF-Setup-${version}.exe",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "SHKF-${version}-portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SHKF",
      "artifactName": "SHKF-Setup-${version}.exe",
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.17",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.106.2",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.3",
    "eventsource": "^4.1.0",
    "lz-string": "^1.5.0",
    "node-global-key-listener": "^0.3.0",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^7.4.2",
    "sharp": "^0.34.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.12"
  }
}
