{
  "name": "shkf",
  "version": "1.2.27",
  "description": "SHKF — hotkeys, Make and templates for Figma",
  "type": "module",
  "main": "app/main.js",
  "author": "SHKF",
  "repository": {
    "type": "git",
    "url": "https://github.com/ruruchin/figma-hotkeys.git"
  },
  "scripts": {
    "start": "electron .",
    "linux": "bash scripts/linux-start.sh",
    "build": "node scripts/electron-build.js nsis",
    "build:portable": "node scripts/electron-build.js portable",
    "build:all": "node scripts/electron-build.js all",
    "build:linux": "bash scripts/linux-build.sh",
    "build:linux:appimage": "bash scripts/linux-build.sh appimage",
    "build:linux:deb": "bash scripts/linux-build.sh deb",
    "build:linux:docker": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/linux-build-docker.ps1",
    "server": "node server/index.js",
    "site:dev": "npm --prefix site run dev",
    "site:build": "npm --prefix site run build",
    "site:preview": "npm --prefix site run preview",
    "seed:supabase": "node supabase/seed-users.mjs",
    "seed:employees": "node supabase/seed-employees.mjs",
    "seed:app-users": "node supabase/seed-app-users.mjs",
    "pik-folder:build-mobbin": "node scripts/build-pik-folder-mobbin-catalog.mjs",
    "ml:export-dataset": "node scripts/export-agent-training-dataset.mjs",
    "ml:export-chat": "node scripts/export-konstancia-chat-dataset.mjs",
    "ml:train": "npm run ml:export-chat && npm run ml:export-dataset && node scripts/run-python.mjs ml/train_all.py",
    "ml:prepare-cloud": "node scripts/ml-prepare-cloud.mjs",
    "ml:download-chat-base": "node scripts/run-python.mjs ml/download_toucan_base.py",
    "ml:download-toucan": "node scripts/run-python.mjs ml/download_toucan_base.py",
    "ml:import-toucan": "node scripts/run-python.mjs ml/import_toucan_sft.py",
    "ml:download-lora": "node scripts/run-python.mjs ml/download_lora_from_hf.py",
    "ml:train:chat": "npm run ml:prepare-cloud",
    "ml:train:chat:local": "npm run ml:import-toucan && npm run ml:export-chat && node scripts/run-python.mjs ml/train_chat_model.py",
    "ml:train:intent": "npm run ml:export-dataset && node scripts/run-python.mjs ml/train_intent_classifier.py",
    "ml:train:retrieval": "node scripts/run-python.mjs ml/train_retrieval_embeddings.py",
    "ml:ingest-knowledge": "node scripts/ingest-knowledge-sources.mjs",
    "ml:train:knowledge": "npm run ml:ingest-knowledge && npm run ml:prepare-cloud && npm run ml:train:retrieval",
    "ml:serve": "cd ml && node ../scripts/run-python.mjs -m uvicorn serve_api:app --host 0.0.0.0 --port 8080",
    "ml:upload-hf": "node scripts/upload-konstancia-to-hf.mjs"
  },
  "build": {
    "appId": "app.shkf",
    "productName": "SHKF",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ruruchin",
        "repo": "SHKF",
        "releaseType": "release"
      }
    ],
    "files": [
      "app/**/*",
      "server/**/*",
      "shared/**/*",
      "config/**/*",
      "supabase/migrations/**/*",
      "scripts/**/*",
      "ml/**/*",
      "!ml/models/**",
      "!ml/vendor/**",
      "!ml/__pycache__/**",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/node-global-key-listener/bin/**/*",
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*",
      "scripts/**/*"
    ],
    "extraResources": [
      {
        "from": "figma-plugin",
        "to": "figma-plugin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "config",
        "to": "config-default",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "scripts",
        "to": "scripts",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "site/public/live2d-model",
        "to": "live2d-model",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "app/renderer/assets/brand/logo.png",
      "artifactName": "SHKF-Setup-${version}.exe",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "SHKF-${version}-portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SHKF",
      "artifactName": "SHKF-Setup-${version}.exe",
      "deleteAppDataOnUninstall": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "icon": "app/renderer/assets/brand/logo.png",
      "artifactName": "SHKF-${version}-${arch}.${ext}",
      "executableName": "shkf",
      "synopsis": "SHKF — hotkeys, Make and templates for Figma",
      "description": "SHKF desktop app with Konstancia agent, Kanban, and Figma tools.",
      "desktop": {
        "entry": {
          "Name": "SHKF",
          "Comment": "SHKF — hotkeys, Make and templates for Figma",
          "Categories": "Utility;Development;",
          "StartupWMClass": "SHKF"
        }
      }
    },
    "deb": {
      "packageName": "shkf",
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libdrm2",
        "libgbm1",
        "libasound2"
      ]
    },
    "appImage": {
      "artifactName": "SHKF-${version}-${arch}.AppImage"
    }
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.17",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.106.2",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.3",
    "eventsource": "^4.1.0",
    "lz-string": "^1.5.0",
    "node-global-key-listener": "^0.3.0",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^7.4.2",
    "sharp": "^0.34.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.12"
  }
}
