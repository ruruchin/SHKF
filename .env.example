SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Only for local seed/admin scripts. Never ship this in the app.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Сотрудники: логин "k.zorenko" -> внутренний email "k.zorenko@<EMPLOYEE_EMAIL_DOMAIN>".
EMPLOYEE_EMAIL_DOMAIN=firuru.local
# Пароль по умолчанию, если не указан в supabase/employees.json (необязательно).
# Тестовый аккаунт для командного чата (npm run seed:test-user)
TEST_USER_PASSWORD=TestChat123!

SEED_DESIGNER_EMAIL=designer@shkf.local
SEED_DESIGNER_PASSWORD=change-me-designer
SEED_DESIGNER_NAME=SHKF Designer

SEED_FRONTEND_EMAIL=frontend@shkf.local
SEED_FRONTEND_PASSWORD=change-me-frontend
SEED_FRONTEND_NAME=SHKF Front-end

SEED_BACKEND_EMAIL=backend@shkf.local
SEED_BACKEND_PASSWORD=change-me-backend
SEED_BACKEND_NAME=SHKF Back-end

SEED_PM_EMAIL=pm@shkf.local
SEED_PM_PASSWORD=change-me-pm
SEED_PM_NAME=SHKF Project Manager

# Konstancia backend (server-side only, not shown in app settings)
KONSTANCIA_YANDEX_API_KEY=
# optional; auto-detected if empty
KONSTANCIA_YANDEX_FOLDER_ID=
# legacy GPU pod fallback (optional)
KONSTANCIA_CLOUD_URL=
KONSTANCIA_CLOUD_API_KEY=
# Hugging Face: upload после облачного train (HF_UPLOAD_REPO на поде) или скачать LoRA на ПК:
# HF_LORA_REPO=your-user/konstancia-chat && npm run ml:download-lora
HF_TOKEN=hf_...
# If HF download fails with SSL EOF on your network:
# HF_HUB_DISABLE_SSL_VERIFY=1
# Offline train after npm run ml:download-chat-base:
# HF_HUB_OFFLINE=1
