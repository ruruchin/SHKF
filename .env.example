SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Only for local seed/admin scripts. Never ship this in the app.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Сотрудники: логин "k.zorenko" -> внутренний email "k.zorenko@<EMPLOYEE_EMAIL_DOMAIN>".
EMPLOYEE_EMAIL_DOMAIN=firuru.local
# Пароль по умолчанию, если не указан в supabase/employees.json (необязательно).
DEFAULT_EMPLOYEE_PASSWORD=ChangeMe123!

SEED_DESIGNER_EMAIL=designer@shkf.local
SEED_DESIGNER_PASSWORD=change-me-designer
SEED_DESIGNER_NAME=SHKF Designer

SEED_FRONTEND_EMAIL=frontend@shkf.local
SEED_FRONTEND_PASSWORD=change-me-frontend
SEED_FRONTEND_NAME=SHKF Front-end

SEED_BACKEND_EMAIL=backend@shkf.local
SEED_BACKEND_PASSWORD=change-me-backend
SEED_BACKEND_NAME=SHKF Back-end

SEED_PM_EMAIL=pm@shkf.local
SEED_PM_PASSWORD=change-me-pm
SEED_PM_NAME=SHKF Project Manager

# Konstancia cloud inference (optional — GPU server with ml/serve_api.py)
KONSTANCIA_CLOUD_URL=https://your-gpu-server:8080
KONSTANCIA_CLOUD_API_KEY=your-secret-key
# Hugging Face upload: npm run ml:upload-hf -- your-user/konstancia-chat
HF_TOKEN=hf_...
